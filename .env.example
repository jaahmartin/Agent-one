# Serveur
PORT=3000

# Base de données (Supabase -> Project Settings > Database > Connection string > URI)
DATABASE_URL=postgresql://user:password@host:5432/postgres

# Twilio (console.twilio.com)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Calendar - compte de service (console.cloud.google.com -> APIs & Services
# -> Identifiants -> Créer des identifiants -> Compte de service -> onglet "Clés"
# -> Ajouter une clé -> JSON). Le fichier téléchargé doit être encodé en base64
# avant d'être collé ici (les retours à la ligne de la clé privée cassent le
# format .env sinon) :
#   base64 -i ~/Downloads/nom-du-fichier.json | pbcopy
# puis colle le résultat (déjà dans le presse-papiers) comme valeur ci-dessous.
GOOGLE_SERVICE_ACCOUNT_KEY=

# URL publique du serveur une fois déployé (Render), utilisée pour les logs/diagnostics
PUBLIC_BASE_URL=https://agent-one.onrender.com

# Utilisées une seule fois par `npm run seed:artisan` pour créer l'artisan pilote en base
ARTISAN_NAME=Jean Dupont Plomberie
ARTISAN_TWILIO_NUMBER=+33612345678
ARTISAN_FORWARDING_NUMBER=+33698765432
# Adresse e-mail de l'agenda de l'artisan, une fois partagé avec le compte de service
ARTISAN_GOOGLE_CALENDAR_ID=jean.dupont@gmail.com
