{
  "name": "agent-one",
  "version": "0.1.0",
  "private": true,
  "description": "Agent ONE - agent IA de réception et qualification de leads pour artisans du bâtiment",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && mkdir -p dist/public && cp -R src/public/. dist/public/",
    "start": "node dist/server.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "calendar:check": "tsx src/scripts/checkCalendarAccess.ts",
    "seed:artisan": "tsx src/scripts/seedArtisan.ts",
    "seed:demo": "tsx src/scripts/seedDemoArtisan.ts",
    "assets:generate": "tsx src/scripts/generateBrandAssets.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.110.0",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.44.6",
    "express": "^4.21.2",
    "google-auth-library": "^9.15.1",
    "googleapis": "^148.0.0",
    "node-cron": "^3.0.3",
    "postgres": "^3.4.5",
    "twilio": "^5.4.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.6",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
